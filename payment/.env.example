# Payment Service Environment Variables

# Server Configuration
PORT=5004
FRONTEND_URL=http://localhost:5173

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/payment-service

# JWT Configuration (should match auth service)
JWT_SECRET=your_jwt_secret_key_here

# Redis Configuration (should match other services)
REDIS_HOST=redis-15158.crce300.ap-south-1-2.ec2.cloud.redislabs.com
REDIS_PORT=15158
REDIS_PASSWORD=your_redis_password_here

# Razorpay Configuration
# Get these from your Razorpay dashboard: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_secret_key_here

# Service URLs (for inter-service communication if needed)
AUTH_SERVICE_URL=http://localhost:5001
ORDER_SERVICE_URL=http://localhost:5003
CART_SERVICE_URL=http://localhost:5002